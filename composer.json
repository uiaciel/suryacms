{
  "name": "uiaciel/suryacms",
  "description": "Surya CMS Laravel Package",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "uiaciel",
      "email": "uiaciel@gmail.com"
    }
  ],
  "require": {
    "php": ">=8.1",
    "illuminate/support": "^11.0|^12.0",
    "livewire/livewire": "^3.0",
    "maatwebsite/excel": "^3.1",
    "spatie/pdf-to-image": "^3.1",
    "barryvdh/laravel-dompdf": "^3.1",
    "intervention/image-laravel": "^1.5"
  },
  "autoload": {
    "files": [
      "src/helpers.php"
    ],
    "psr-4": {
      "Uiaciel\\SuryaCms\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Uiaciel\\SuryaCms\\SuryaCmsServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}